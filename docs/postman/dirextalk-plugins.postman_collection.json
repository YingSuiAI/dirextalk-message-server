          "raw": "{\n  \"action\": \"plugins.invoke\",\n  \"params\": {\n    \"plugin_id\": \"io.dirextalk.agent\",\n    \"action\": \"agent.chat\",\n    \"params\": {\n      \"prompt\": \"Hello from Dirextalk\",\n      \"model_profile_id\": \"deepseek:deepseek-chat\",\n      \"model_profile\": {\n        \"id\": \"deepseek:deepseek-chat\",\n        \"name\": \"deepseek/deepseek-chat\",\n        \"provider\": \"deepseek\",\n        \"model\": \"deepseek-chat\",\n        \"base_url\": \"https://api.deepseek.com\",\n        \"api_key\": \"{{agentApiKey}}\",\n        \"temperature\": 0.2,\n        \"max_output_tokens\": 2048,\n        \"context_window\": 30,\n        \"top_p\": 1.0,\n        \"top_k\": 0\n      },\n      \"conversation_context\": {\n        \"summary\": \"User prefers concise Chinese answers.\",\n        \"messages\": [\n          {\n            \"role\": \"user\",\n            \"text\": \"你好\"\n          },\n          {\n            \"role\": \"assistant\",\n            \"text\": \"你好，我可以帮你做什么？\"\n          }\n        ]\n      }\n    }\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
