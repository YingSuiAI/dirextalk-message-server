{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YingSuiAI/dirextalk-message-server/raw/main/release/release-manifest.schema.json",
  "title": "Dirextalk Message Server release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "version",
    "image",
    "image_digest",
    "upgrade_from",
    "schema_version",
    "schema_compat_version",
    "minimum_client_version",
    "maximum_client_version_exclusive",
    "backup_required",
    "rollback_supported",
    "rollback_mode",
    "release_notes_url"
  ],
  "properties": {
    "manifest_version": { "const": 1 },
    "version": {
      "type": "string",
      "pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
    },
    "image": { "type": "string", "minLength": 1 },
    "image_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "upgrade_from": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "schema_version": { "type": "integer", "minimum": 1 },
    "schema_compat_version": { "type": "integer", "minimum": 1 },
    "minimum_client_version": {
      "type": "string",
      "pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
    },
    "maximum_client_version_exclusive": {
      "type": "string",
      "pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
    },
    "backup_required": { "const": true },
    "rollback_supported": { "type": "boolean" },
    "rollback_mode": { "enum": ["", "restore_backup"] },
    "release_notes_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github\\.com/.+/releases/tag/v[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  }
}
