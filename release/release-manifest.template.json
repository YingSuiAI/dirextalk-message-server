{
  "manifest_version": 1,
  "version": "${VERSION}",
  "image": "dirextalk/message-server:${VERSION}",
  "image_digest": "${IMAGE_DIGEST}",
  "upgrade_from": [
    "${UPGRADE_FROM}"
  ],
  "schema_version": 1,
  "schema_compat_version": 1,
  "minimum_client_version": "${MINIMUM_CLIENT_VERSION}",
  "maximum_client_version_exclusive": "${MAXIMUM_CLIENT_VERSION_EXCLUSIVE}",
  "backup_required": true,
  "rollback_supported": true,
  "rollback_mode": "restore_backup",
  "release_notes_url": "https://github.com/YingSuiAI/dirextalk-message-server/releases/tag/${VERSION}"
}
