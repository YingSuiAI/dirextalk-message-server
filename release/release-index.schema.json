{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YingSuiAI/dirextalk-message-server/raw/main/release/release-index.schema.json",
  "title": "Dirextalk Message Server trusted release index",
  "type": "object",
  "additionalProperties": false,
  "required": ["release_index_version", "latest_version", "releases", "upgrade_edges"],
  "properties": {
    "release_index_version": { "const": 1 },
    "latest_version": { "type": "string", "pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$" },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["manifest", "manifest_digest"],
        "properties": {
          "manifest": { "$ref": "./release-manifest.schema.json" },
          "manifest_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        }
      }
    },
    "upgrade_edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_version", "from_image_digests", "to_version"],
        "properties": {
          "from_version": { "type": "string", "pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$" },
          "from_image_digests": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
          },
          "to_version": { "type": "string", "pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$" }
        }
      }
    }
  }
}
