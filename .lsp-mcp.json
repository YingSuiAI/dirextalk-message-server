{
  "servers": [
    {
      "id": "go",
      "extensions": [".go"],
      "languageIds": ["go"],
      "command": "/Users/bigdeal/go/bin/gopls",
      "args": ["serve"],
      "rootPatterns": ["go.work", "go.mod"],
      "env": {
        "GOTOOLCHAIN": "auto"
      }
    }
  ],
  "requestTimeout": 120000,
  "autoStart": true,
  "logLevel": "info",
  "idleTimeout": 1800000
}
